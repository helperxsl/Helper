--// SISTEMA ESP (OPTIMIZADO CADA 0.5s)
task.spawn(function()
	while task.wait(0.5) do
		for _, p in pairs(Players:GetPlayers()) do
			if p ~= player and p.Character then
				local hi = p.Character:FindFirstChild("ESPHighlight")
				if config.HighlightESP then
					if not hi then
						hi = Instance.new("Highlight")
						hi.Name = "ESPHighlight"
						hi.FillColor = Color3.fromRGB(255, 0, 0)
						hi.FillTransparency = 0.5
						hi.OutlineColor = Color3.new(1, 1, 1)
						hi.Parent = p.Character
					end
					hi.Enabled = true
				elseif hi then
					hi.Enabled = false
				end
			end
		end
	end
end)

--// BUCLE DE FÍSICA Y MOVIMIENTO (RENDERSTEPPED)
RunService.RenderStepped:Connect(function()
	local char = player.Character
	if not char then return end
	local hum = char:FindFirstChild("Humanoid")
	local hrp = char:FindFirstChild("HumanoidRootPart")

	-- NoClip ligero
	if config.NoClip then
		if char:FindFirstChild("Head") then char.Head.CanCollide = false end
		if char:FindFirstChild("UpperTorso") then char.UpperTorso.CanCollide = false end
		if char:FindFirstChild("LowerTorso") then char.LowerTorso.CanCollide = false end
		if hrp then hrp.CanCollide = false end
	end

	-- Wall Climb
	if config.WallClimb and hrp then
		local ray = Ray.new(hrp.Position, hrp.CFrame.LookVector * 2.5)
		local hit = workspace:FindPartOnRay(ray, char)
		if hit and UIS:IsKeyDown(Enum.KeyCode.Space) then hrp.Velocity = Vector3.new(hrp.Velocity.X, 45, hrp.Velocity.Z) end
	end

	-- Hitbox Expander
	if config.HitboxEnabled then
		for _, p in pairs(Players:GetPlayers()) do
			if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
				local ehrp = p.Character.HumanoidRootPart
				if ehrp.Size.X ~= config.HitboxSize then
					ehrp.Size = Vector3.new(config.HitboxSize, config.HitboxSize, config.HitboxSize)
					ehrp.Transparency = 0.8
					ehrp.CanCollide = false
				end
			end
		end
	end

	-- SHIFT LOCK LÓGICA
	if config.ShiftLock and hrp and hum then
		local look = camera.CFrame.LookVector
		-- Alinea el cuerpo con la cámara
		hrp.CFrame = CFrame.new(hrp.Position) * CFrame.Angles(0, math.atan2(-look.X, -look.Z), 0)
		-- Desplaza la cámara al hombro
		hum.CameraOffset = config.Offset
		hum.AutoRotate = false
	elseif hum then
		hum.CameraOffset = Vector3.new(0,0,0)
		hum.AutoRotate = true
	end
end)

--// ACCIONES DE USUARIO
UIS.JumpRequest:Connect(function() if config.InfJump and player.Character and player.Character:FindFirstChild("Humanoid") then player.Character.Humanoid:ChangeState("Jumping") end end)

--// COMBATE AGRESIVO (TASK SEPARADO)
task.spawn(function()
	while true do
		local char = player.Character
		local tool = char and char:FindFirstChildOfClass("Tool")
		if tool and tool.Name == "Katana" then
			local targetInAura = false
			if config.KillAura then
				for _, p in pairs(Players:GetPlayers()) do
					if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
						if (char.HumanoidRootPart.Position - p.Character.HumanoidRootPart.Position).Magnitude <= config.AuraRange then
							targetInAura = true
							VirtualUser:CaptureController(); VirtualUser:Button1Down(Vector2.new(0,0))
							task.wait(0.02); VirtualUser:Button1Up(Vector2.new(0,0))
						end
					end
				end
			end
			if not targetInAura and config.AutoClick and menu.Visible == false then
				VirtualUser:CaptureController(); VirtualUser:Button1Down(Vector2.new(0,0))
				task.wait(0.05); VirtualUser:Button1Up(Vector2.new(0,0))
			end
		end
		task.wait(0.08)
	end
end)
